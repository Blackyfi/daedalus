{
  "title": "Daedalus — Overview",
  "uid": "daedalus-overview",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": {"from": "now-1h", "to": "now"},
  "panels": [
    {
      "type": "stat",
      "title": "Queue depth (urgent)",
      "gridPos": {"x": 0, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "daedalus_queue_depth{lane=\"urgent\"}"}]
    },
    {
      "type": "stat",
      "title": "Queue depth (default)",
      "gridPos": {"x": 6, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "daedalus_queue_depth{lane=\"default\"}"}]
    },
    {
      "type": "stat",
      "title": "Queue depth (bg)",
      "gridPos": {"x": 12, "y": 0, "w": 6, "h": 4},
      "targets": [{"expr": "daedalus_queue_depth{lane=\"bg\"}"}]
    },
    {
      "type": "timeseries",
      "title": "Run completions by state",
      "gridPos": {"x": 0, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (state) (rate(daedalus_runs_completed_total[5m]))"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Argus verdicts",
      "gridPos": {"x": 12, "y": 4, "w": 12, "h": 8},
      "targets": [
        {"expr": "sum by (verdict) (rate(daedalus_argus_verdicts_total[5m]))"}
      ]
    },
    {
      "type": "timeseries",
      "title": "Run duration p95 (s)",
      "gridPos": {"x": 0, "y": 12, "w": 24, "h": 8},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, kind) (rate(daedalus_run_duration_seconds_bucket[5m])))"}
      ]
    }
  ]
}
