# --- Daedalus environment ---
# Copy to .env and fill in. Secrets in deploy/secrets/ override these for sensitive values.

# Public URL the platform is reachable at (used in OTP emails, CSP, etc.)
# Include the port if it isn't 443 (e.g. https://daedalus.your.lan:9443).
DAEDALUS_PUBLIC_URL=https://daedalus.your.lan:9443

# Host ports Caddy publishes. Defaults avoid the common 80/443/8080/8443.
DAEDALUS_HTTPS_PORT=9443
DAEDALUS_HTTP_PORT=9080

# How workers (hermes/talos) reach the API container over backnet — never via
# the public mTLS URL, since they don't have client certs.
INTERNAL_API_BASE=http://api:8000

# Postgres
POSTGRES_USER=daedalus
POSTGRES_PASSWORD=changeme
POSTGRES_DB=daedalus
DATABASE_URL=postgresql+asyncpg://daedalus:changeme@postgres:5432/daedalus

# Redis
REDIS_URL=redis://redis:6379/0

# MinIO (S3-compatible blob store)
MINIO_ROOT_USER=daedalus
MINIO_ROOT_PASSWORD=changeme-minio
MINIO_BUCKET=daedalus
S3_ENDPOINT=http://minio:9000
S3_ACCESS_KEY=daedalus
S3_SECRET_KEY=changeme-minio
DAEDALUS_OBJECTS_DIR=/tmp/daedalus-objects

# Auth
SESSION_SECRET=replace-me-with-64-bytes-of-random
PASSWORD_PEPPER=replace-me-with-64-bytes-of-random
# Bearer key for worker→API internal routes. Set to a distinct random value
# (do NOT reuse SESSION_SECRET). Falls back to SESSION_SECRET if left blank.
INTERNAL_API_KEY=replace-me-with-another-64-bytes-of-random
# Optional: application-level encryption key for the TOTP secret at rest.
# Falls back to a key derived from PASSWORD_PEPPER if left blank.
TOTP_ENC_KEY=
SESSION_IDLE_MINUTES=480
SESSION_HARD_HOURS=168
LOCKOUT_THRESHOLD=5
LOCKOUT_MINUTES=15
IP_BAN_THRESHOLD=25
IP_BAN_MINUTES=60

# SMTP (for email OTP)
SMTP_HOST=smtp.your.lan
SMTP_PORT=587
SMTP_USER=daedalus
SMTP_PASSWORD=changeme-smtp
SMTP_FROM=daedalus@your.lan
SMTP_TLS=true

# --- TLS / mTLS posture ---
# Default: Caddy auto-issues server certs from its own internal CA
# (`tls internal`); add the resulting root cert to your browser trust
# store once. mTLS is off — Tailscale ACL + 3FA + WebAuthn handle
# identity. Toggle below if you'd rather enforce mTLS.
PUBLIC_HOST=daedalus.your.lan
LOCAL_HOST=daedalus
REQUIRE_CLIENT_CERT=false

# Used only when REQUIRE_CLIENT_CERT=true: Caddy's `client_auth` block
# expects these files in deploy/secrets/.
INTERNAL_CA_BUNDLE=/run/secrets/internal_ca.crt
TLS_CERT=/run/secrets/server.crt
TLS_KEY=/run/secrets/server.key

# Talos
TALOS_WORKSPACES_ROOT=/workspaces
TALOS_CONNECTORS_DIR=/etc/daedalus/connectors

# --- Hermes scheduling (per-project concurrency) ---
# Global ceiling on concurrent runs across all projects (one Daedalus-managed
# run per project; the cap limits how many *projects* can run at once).
# With Pro Max-x20 + a safelock fallback the meaningful cap is host CPU/RAM,
# not API rate limits — tune to your machine.
MAX_CONCURRENT_PROJECTS=4
SCHEDULER_POLL_SECONDS=0.5
PROJECT_LEASE_GRACE_SECONDS=300
PROJECT_LEASE_HEARTBEAT_SECONDS=60

# --- Pythia (subscription oracle) ---
# Talos probes `claude --print "/status"` periodically and caches the result
# in Redis so the dashboard can show plan tier + remaining quota without
# blocking on the CLI.
PYTHIA_REFRESH_SECONDS=600
PYTHIA_PROBE_TIMEOUT_SECONDS=10
PYTHIA_CACHE_TTL_SECONDS=1800

# --- Workspaces / discovery ---
# Host directory containing the user's git repos. Mounted into api/talos at
# /workspaces and walked by the "Discover repos" flow on the project list
# page. Default keeps the legacy `deploy/workspaces` sandbox; point it at
# wherever your real source trees live (e.g. /home/you/git-repos-projects).
HOST_WORKSPACES_ROOT=../deploy/workspaces

# Iris
IRIS_PORT=8001

# Cost / token tracking
ENABLE_TOKEN_TRACKING=true

# --- LLM (used by Argus + planning) ---
# Any OpenAI-compatible /v1/chat/completions endpoint:
# vLLM, NVIDIA NIM, llama.cpp --server, Ollama (/v1), LM Studio, OpenAI, etc.
# On a GB10 / Blackwell box, vLLM with NVFP4 is the sweet spot.
LLM_BASE_URL=http://llm:8000/v1
LLM_API_KEY=
LLM_MODEL=Qwen/Qwen2.5-Coder-32B-Instruct
LLM_VERIFIER_MODEL=
LLM_TIMEOUT_SECONDS=120
LLM_MAX_DIFF_CHARS=60000
LLM_MAX_LOG_CHARS=20000

# --- Self-hosted vLLM (only used when `--profile llm` is on) ---
# Pinned image tag; bump when vLLM ships a release you've validated.
VLLM_IMAGE=vllm/vllm-openai:v0.6.4.post1
# How many GPUs to expose. `all` uses every visible GPU.
VLLM_GPU_COUNT=all
# Tensor-parallel sharding across those GPUs. 1 for single-GPU, 2/4/8 for multi-GPU.
VLLM_TENSOR_PARALLEL_SIZE=1
# Cap on KV-cache + attention window. Lower this to fit larger batches in less VRAM.
VLLM_MAX_MODEL_LEN=32768
# Fraction of each GPU's VRAM vLLM is allowed to grab.
VLLM_GPU_MEMORY_UTILIZATION=0.90
# `auto` lets vLLM pick. Override to `bfloat16`, `float16`, `float8`, etc.
VLLM_DTYPE=auto
# Free-form extra flags appended verbatim, e.g. `--trust-remote-code --enforce-eager`.
VLLM_EXTRA_ARGS=
VLLM_LOGGING_LEVEL=INFO
# Optional HuggingFace token if your chosen model is gated. Leave empty for public models.
HF_TOKEN=

# --- Observability ports (only published when --profile observability is on) ---
DAEDALUS_PROMETHEUS_PORT=9090
DAEDALUS_GRAFANA_PORT=9300
DAEDALUS_MAILPIT_UI_PORT=9025
GRAFANA_ADMIN_PASSWORD=admin

# --- Build flags ---
# Empty for prod. Set to `dev` (or e.g. `dev,test`) to install pyproject extras
# in the backend image. Forwarded to Dockerfile's DAEDALUS_INSTALL_EXTRAS arg.
DAEDALUS_INSTALL_EXTRAS=

# --- Postgres backup sidecar (always on) ---
# Cron-style time to run the nightly pg_dump. Default is 02:30 UTC.
PG_BACKUP_SCHEDULE=30 2 * * *
# How many days of dumps to keep in MinIO before pruning.
PG_BACKUP_RETENTION_DAYS=30
# MinIO bucket for dumps. The sidecar creates it on first run if it's absent.
PG_BACKUP_BUCKET=daedalus-backups

# --- agentnet egress firewall sidecar (always on) ---
# How often the sidecar reloads connector specs and re-applies iptables rules
# (in seconds). Bump if you have lots of connectors or rules churn.
AGENTNET_FIREWALL_RELOAD_SECONDS=120
# Hosts allowed for *every* run, regardless of connector. Comma-separated
# hostnames; resolved at apply time.
AGENTNET_FIREWALL_BASELINE_HOSTS=api.anthropic.com,api.openai.com
