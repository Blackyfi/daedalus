# --- python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
coverage.xml

# --- node ---
node_modules/
dist/
.vite/
.turbo/
.parcel-cache/
*.tsbuildinfo
.eslintcache
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- env / secrets ---
# All env files are private; the committed example sets the contract.
.env
.env.*
!.env.example
deploy/secrets/*
!deploy/secrets/.gitkeep
!deploy/secrets/README.md
deploy/workspaces/*
!deploy/workspaces/.gitkeep
deploy/data/

# Cert/key material — defence in depth. CA bundles, server certs, OAuth
# tokens etc. live in deploy/secrets/ (already ignored above); these
# globs catch anything that escapes that directory.
*.crt
*.key
*.pem
*.p12
*.pfx
*.csr

# Local dev databases.
*.db
*.sqlite
*.sqlite3
*.sqlite-journal

# --- editor / os ---
.idea/
.vscode/
*.swp
*.swo
*.bak
*.orig
.DS_Store
Thumbs.db

# --- runtime artefacts ---
# Talos creates per-run git worktrees at <workspace>/runs/<run_id>; when
# the daedalus repo IS the workspace, those land here. Never to be
# committed — they're transient working trees.
runs/
# A writability probe occasionally drops this on the workspace root.
test_write_root

# --- build / log artefacts ---
*.log
*.pid
*.sock
*.tar.gz
*.tar
*.tgz
frontend/vite.config.js
frontend/vite.config.d.ts
