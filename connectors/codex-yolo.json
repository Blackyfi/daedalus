{
  "id": "codex-yolo",
  "display_name": "Codex (yolo)",
  "description": "Codex CLI with full permissions. Daedalus snapshots the workspace before each run.",
  "command": "codex",
  "args": ["--auto-approve"],
  "env": {
    "OPENAI_API_KEY": "{{secret:openai_key}}"
  },
  "workdir": "{{project.workspace_path}}",
  "permission_profile": "yolo",
  "input_format": {
    "kind": "stdin_prompt",
    "template": "Task: {{task.title}}\n\n{{task.description}}\n\nAcceptance criteria:\n{{task.acceptance_criteria}}\n"
  },
  "done_signal": {
    "kind": "exit_code",
    "exit_code": 0
  },
  "exit_on_done": true,
  "verify_commands": [
    "git status --short"
  ],
  "argus_profile": {
    "command": "codex",
    "args": ["--read-only"],
    "workdir_readonly": true
  },
  "resource_limits": {
    "cpu_shares": 1024,
    "memory_mb": 4096,
    "wall_clock_minutes": 75,
    "idle_output_minutes": 12
  },
  "interrupt": {
    "soft": "SIGINT",
    "hard": "SIGTERM",
    "kill_grace_seconds": 5
  },
  "tags": ["coding", "codex", "yolo"],
  "usage_parser": {
    "kind": "openai"
  }
}
