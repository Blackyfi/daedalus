{
  "id": "codex-confirm",
  "display_name": "Codex (confirm)",
  "description": "Codex CLI with an approval-oriented profile for Daedalus task runs.",
  "command": "codex",
  "args": [],
  "workdir": "{{project.workspace_path}}",
  "permission_profile": "confirm",
  "input_format": {
    "kind": "stdin_prompt",
    "template": "Task: {{task.title}}\n\n{{task.description}}\n\nAcceptance criteria:\n{{task.acceptance_criteria}}\n"
  },
  "done_signal": {
    "kind": "exit_code",
    "exit_code": 0
  },
  "exit_on_done": true,
  "verify_commands": [
    "git status --short"
  ],
  "argus_profile": {
    "command": "codex",
    "args": [],
    "workdir_readonly": true
  },
  "resource_limits": {
    "cpu_shares": 1024,
    "memory_mb": 4096,
    "wall_clock_minutes": 60,
    "idle_output_minutes": 10
  },
  "interrupt": {
    "soft": "SIGINT",
    "hard": "SIGTERM",
    "kill_grace_seconds": 5
  },
  "tags": [
    "coding",
    "codex",
    "safe"
  ],
  "usage_parser": {
    "kind": "openai"
  }
}
