{
  "id": "shell-demo",
  "display_name": "Shell Demo",
  "description": "Minimal connector for validating Talos PTY execution with a plain shell.",
  "command": "bash",
  "args": [
    "-lc",
    "cat >/tmp/daedalus-task.txt && printf 'DONE\\n'"
  ],
  "workdir": "{{project.workspace_path}}",
  "permission_profile": "confirm",
  "input_format": {
    "kind": "stdin_prompt",
    "template": "{{task.title}}\n\n{{task.description}}\n"
  },
  "done_signal": {
    "kind": "exit_code",
    "exit_code": 0
  },
  "exit_on_done": true,
  "verify_commands": [
    "test -f /tmp/daedalus-task.txt"
  ],
  "argus_profile": {
    "command": "bash",
    "args": [
      "-lc",
      "printf 'argus verification stub\\n'"
    ],
    "workdir_readonly": true
  },
  "resource_limits": {
    "cpu_shares": 256,
    "memory_mb": 256,
    "wall_clock_minutes": 10,
    "idle_output_minutes": 2
  },
  "interrupt": {
    "soft": "SIGINT",
    "hard": "SIGTERM",
    "kill_grace_seconds": 2
  },
  "tags": [
    "demo",
    "shell"
  ]
}
